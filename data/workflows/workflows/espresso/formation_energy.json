        {
            "_id": "196c6da2-465d-5140-989e-48b1fb1cbb72",
            "name": "Get Elemental Materials",
            "application": {
                "name": "shell",
                "shortName": "sh",
                "summary": "Shell Script",
                "build": "GNU",
                "isDefault": true,
