            "data": {}
        }
    },
    "units": [
        {
            "name": "assign-elements",
            "type": "assignment",
            "operand": "ELEMENTS",
            "value": "sorted(list(set([e['value'] for e in MATERIAL.basis.elements])))",
            "input": [],
            "results": [],
            "monitors": [],
            "preProcessors": [],
            "postProcessors": [],
            "status": "idle",
            "statusTrack": [],
            "tags": [],
            "flowchartId": "assign-elements",
            "head": true,
            "next": "assert-elements",
            "schemaVersion": "2022.8.16",
            "isDefault": false
        },
        {
            "name": "assert-elements",
            "type": "assertion",
            "statement": "len(ELEMENTS) > 0",
            "errorMessage": "Material has no elements in its basis.",
            "results": [],
            "monitors": [],
            "preProcessors": [],
            "postProcessors": [],
            "status": "idle",
            "statusTrack": [],
            "tags": [],
            "flowchartId": "assert-elements",
            "head": false,
            "next": "io-elemental-materials",
            "schemaVersion": "2022.8.16",
            "isDefault": false
        },
        {
            "name": "io-elemental-materials",
            "type": "io",
            "subtype": "input",
            "results": [],
            "monitors": [],
            "preProcessors": [],
            "postProcessors": [],
            "status": "idle",
            "statusTrack": [],
            "tags": [],
            "flowchartId": "io-elemental-materials",
            "source": "api",
            "input": [
                {
                    "type": "api",
                    "endpoint": "materials",
                    "endpoint_options": {
                        "params": {
                            "query": "{'tags': 'elemental', 'metadata.element': {'$in': ELEMENTS}}",
                            "projection": "{}"
                        }
                    },
                    "name": "DATA"
                }
            ],
            "head": false,
            "next": "assign-element-materials",
            "schemaVersion": "2022.8.16",
            "isDefault": false
        },
        {
            "name": "assign-element-materials",
            "type": "assignment",
            "operand": "ELEMENT_MATERIALS",
            "value": "{m['metadata']['element']: m for m in DATA if m.get('metadata') and m['metadata'].get('element') in ELEMENTS}",
            "input": [
                {
                    "name": "DATA",
                    "scope": "io-elemental-materials"
                }
            ],
            "results": [],
            "monitors": [],
            "preProcessors": [],
            "postProcessors": [],
            "status": "idle",
            "statusTrack": [],
