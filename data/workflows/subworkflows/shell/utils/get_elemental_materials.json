            "flowchartId": "assign-element-materials",
            "head": false,
            "next": "assert-element-materials",
            "schemaVersion": "2022.8.16",
            "isDefault": false
        },
        {
            "name": "assert-element-materials",
            "type": "assertion",
            "statement": "set(ELEMENT_MATERIALS.keys()) == set(ELEMENTS)",
            "errorMessage": "Elemental reference material(s) not found on the Platform. Import missing elements from Standata Materials Bank (tags: elemental, metadata.element).",
