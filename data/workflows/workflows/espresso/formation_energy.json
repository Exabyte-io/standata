                    "data": {}
                }
            },
            "units": [
                {
                    "name": "assign-elements",
                    "type": "assignment",
                    "operand": "ELEMENTS",
                    "value": "sorted(list(set([e['value'] for e in MATERIAL.basis.elements])))",
                    "input": [],
                    "flowchartId": "assign-elements",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": true,
                    "next": "assert-elements",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assert-elements",
                    "type": "assertion",
                    "statement": "len(ELEMENTS) > 0",
                    "errorMessage": "Material has no elements in its basis.",
                    "flowchartId": "assert-elements",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "io-elemental-materials",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
