                    }
                },
                {
                    "name": "io-elemental-materials",
                    "type": "io",
                    "subtype": "input",
                    "flowchartId": "io-elemental-materials",
                    "source": "api",
                    "input": [
                        {
                            "endpoint": "materials",
                            "endpoint_options": {
                                "params": {
                                    "query": "{'tags': 'elemental', 'metadata.element': {'$in': ELEMENTS}}",
                                    "projection": "{}"
                                }
                            },
                            "name": "DATA"
                        }
                    ],
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "assign-element-materials",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assign-element-materials",
                    "type": "assignment",
                    "operand": "ELEMENT_MATERIALS",
                    "value": "{m['metadata']['element']: m for m in DATA if m.get('metadata') and m['metadata'].get('element') in ELEMENTS}",
                    "input": [
                        {
                            "name": "DATA",
                            "scope": "io-elemental-materials"
                        }
                    ],
                    "flowchartId": "assign-element-materials",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "assert-element-materials",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assert-element-materials",
                    "type": "assertion",
                    "statement": "set(ELEMENT_MATERIALS.keys()) == set(ELEMENTS)",
                    "errorMessage": "Elemental reference material(s) not found on the Platform. Import missing elements from Standata Materials Bank (tags: elemental, metadata.element).",
                    "flowchartId": "assert-element-materials",
                    "status": "idle",
