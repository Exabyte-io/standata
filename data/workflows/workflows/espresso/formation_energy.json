        {
            "_id": "17adeec3-aa75-5d67-9617-9b4a0e4b06e9",
            "name": "Get Elemental Energies",
            "application": {
                "name": "shell",
                "shortName": "sh",
                "summary": "Shell Script",
                "build": "GNU",
                "isDefault": true,
                "version": "5.1.8",
                "schemaVersion": "2022.8.16"
            },
            "properties": [],
            "model": {
                "type": "unknown",
                "subtype": "unknown",
                "method": {
                    "type": "unknown",
                    "subtype": "unknown",
                    "data": {}
                }
            },
            "units": [
                {
                    "name": "io-elemental-energies",
                    "type": "io",
                    "subtype": "input",
                    "flowchartId": "io-elemental-energies",
                    "source": "api",
                    "input": [
                        {
                            "endpoint": "refined-properties",
                            "endpoint_options": {
                                "params": {
                                    "query": "{'exabyteId': {'$in': [ELEMENT_MATERIALS[el].exabyteId for el in ELEMENTS]}, 'slug': 'total_energy'}",
                                    "projection": "{'sort': {'precision.value': -1}, 'limit': min(500, max(20, len(ELEMENTS) * 10))}"
                                }
                            },
                            "name": "DATA"
                        }
                    ],
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": true,
                    "next": "assign-elemental-energies",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assign-elemental-energies",
                    "type": "assignment",
                    "operand": "E_ELEMENTAL_BY_SYMBOL",
                    "value": "{el: ([d.data.value for d in DATA if (d.exabyteId == ELEMENT_MATERIALS[el].exabyteId or ELEMENT_MATERIALS[el].exabyteId in d.exabyteId)] or [None])[0] for el in ELEMENTS}",
                    "input": [
                        {
                            "name": "DATA",
                            "scope": "io-elemental-energies"
                        }
                    ],
                    "flowchartId": "assign-elemental-energies",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "assign-missing-elemental-energies",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assign-missing-elemental-energies",
                    "type": "assignment",
                    "operand": "MISSING_ELEMENTAL_ENERGIES",
                    "value": "[el for el in ELEMENTS if E_ELEMENTAL_BY_SYMBOL[el] is None]",
                    "input": [],
                    "flowchartId": "assign-missing-elemental-energies",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "assign-elemental-energies-error",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assign-elemental-energies-error",
                    "type": "assignment",
                    "operand": "ELEMENTAL_ENERGIES_ERROR_MSG",
                    "value": "'Missing elemental total_energy for: ' + ', '.join(MISSING_ELEMENTAL_ENERGIES) + '. Run QE total energy on Standata elemental materials (tags: elemental).' + ' exabyteIds: ' + ', '.join([el + '=' + ELEMENT_MATERIALS[el].exabyteId for el in MISSING_ELEMENTAL_ENERGIES])",
                    "input": [],
                    "flowchartId": "assign-elemental-energies-error",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "assert-elemental-energies",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assert-elemental-energies",
                    "type": "assertion",
                    "statement": "len(MISSING_ELEMENTAL_ENERGIES) == 0",
                    "errorMessage": "ELEMENTAL_ENERGIES_ERROR_MSG",
                    "flowchartId": "assert-elemental-energies",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "next": "assign-elemental-energy-sum",
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                },
                {
                    "name": "assign-elemental-energy-sum",
                    "type": "assignment",
                    "operand": "E_ELEMENTAL_SUM",
                    "value": "sum(E_ELEMENTAL_BY_SYMBOL[e['value']] / len(ELEMENT_MATERIALS[e['value']].basis.elements) for e in MATERIAL.basis.elements)",
                    "input": [],
                    "flowchartId": "assign-elemental-energy-sum",
                    "status": "idle",
                    "statusTrack": [],
                    "tags": [],
                    "head": false,
                    "application": {
                        "name": "shell",
                        "shortName": "sh",
                        "summary": "Shell Script",
                        "build": "GNU",
                        "isDefault": true,
                        "version": "5.1.8",
                        "schemaVersion": "2022.8.16"
                    }
                }
            ]
        },
