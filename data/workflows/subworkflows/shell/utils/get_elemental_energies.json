                            "query": "{'exabyteId': {'$in': [ELEMENT_MATERIALS[el].exabyteId for el in ELEMENTS]}, 'slug': 'total_energy'}",
                            "projection": "{'sort': {'precision.value': -1}, 'limit': min(500, max(20, len(ELEMENTS) * 10))}"
